# Featherless API key — small model for Step 1 scoping (Qwen2.5-7B-Instruct)
FEATHERLESS_API_KEY=rc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic API key — Claude Sonnet for Step 3 strategy (optional; deterministic fallback)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Sybilion Ops API — Step 2 forecasts (only needed when USE_MOCK=0)
SYBILION_API_KEY=sk_ops_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SYBILION_BASE_URL=https://api.sybilion.dev

# Twelve Data — optional, refreshes the current month from an hourly FX feed
TWELVEDATA_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Use synthetic forecasts (no keys/network needed). Set to 0 to go live against Sybilion.
USE_MOCK=1
